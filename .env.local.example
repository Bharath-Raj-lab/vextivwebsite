# ──────────────────────────────────────────────
# Vextiv Studio — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=

# Meta Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp number without +, e.g. 919XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Supabase project URL (NEXT_PUBLIC_ so it's accessible in browser bundles)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (safe to expose — RLS enforces access control)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key — SERVER ONLY
RESEND_API_KEY=

# Sender email address shown as From:, e.g. hello@vextiv.com
RESEND_FROM_EMAIL=

# Internal team address that receives lead notifications
TEAM_EMAIL=

# Upstash Redis REST URL — SERVER ONLY
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — SERVER ONLY
UPSTASH_REDIS_REST_TOKEN=
